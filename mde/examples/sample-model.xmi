<?xml version="1.0" encoding="UTF-8"?>
<XMI xmi:version="2.0" xmlns:xmi="http://www.omg.org/XMI" xmlns:uml="http://idm.example.org/uml">
  <uml:UMLModel>
    <classes>
      <uml:UMLClass name="Person" visibility="public" abstract="false">
        <attributes name="name" type="String" visibility="private" multiplicity="1"/>
        <attributes name="age" type="int" visibility="private" multiplicity="1"/>
        <methods name="getName" returnType="String" visibility="public"/>
      </uml:UMLClass>
      <uml:UMLClass name="Employee" visibility="public" abstract="false">
        <attributes name="employeeId" type="String" visibility="private" multiplicity="1"/>
      </uml:UMLClass>
    </classes>
    <relations>
      <uml:UMLRelation source="Employee" target="Person" type="inheritance" cardinality="1"/>
    </relations>
  </uml:UMLModel>
</XMI>
